OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5
FALLBACK_OPENAI_MODEL=gpt-4.1-mini
DEFAULT_LLM_PROVIDER=mock
DEFAULT_VISION_PROVIDER=mock
ENABLE_VISION=true
ENABLE_CRITIC=true
ENABLE_REPAIR=true
MAX_REPAIR_LOOPS=2
REASONING_EFFORT=low
VERBOSITY=low
TEMPERATURE=0.2
PATCH_MODE=true
REVISION_MAX_OUTPUT_TOKENS=1200
NORMAL_MAX_OUTPUT_TOKENS=4000
STORAGE_DIR=storage
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_API_BASE_URL=http://127.0.0.1:8000
